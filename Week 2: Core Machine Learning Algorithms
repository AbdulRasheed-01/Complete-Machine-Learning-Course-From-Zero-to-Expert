    plt.scatter(X_test_r, y_test_r, alpha=0.7, label='Test', s=50, c='red')
    plt.plot(X_smooth, y_smooth, 'g-', linewidth=2, label='KNN prediction')
    plt.xlabel('X')
    plt.ylabel('y')
    plt.title(f'KNN Regression (k={k}, MSE={mse:.2f})')
    plt.legend()
    plt.grid(True, alpha=0.3)

