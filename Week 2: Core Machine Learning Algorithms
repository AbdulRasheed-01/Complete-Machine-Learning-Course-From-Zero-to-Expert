# 6. Visualize decision boundary
print("\n4. VISUALIZING DECISION BOUNDARY:")

def plot_decision_boundary(X, y, model, title):
    """Plot decision boundary of a classifier"""
    h = 0.02  # step size in the mesh
    
    # Create a mesh grid
    x_min, x_max = X[:, 0].min() - 1, X[:, 0].max() + 1
    y_min, y_max = X[:, 1].min() - 1, X[:, 1].max() + 1
    xx, yy = np.meshgrid(np.arange(x_min, x_max, h),
                         np.arange(y_min, y_max, h))
    
    # Predict on mesh grid
    Z = model.predict(np.c_[xx.ravel(), yy.ravel()])
    Z = Z.reshape(xx.shape)
    
    # Plot
    plt.figure(figsize=(10, 8))
    plt.contourf(xx, yy, Z, alpha=0.3, cmap='coolwarm')
    plt.scatter(X[y==0, 0], X[y==0, 1], c='blue', edgecolors='black', 
                label='Class 0', s=50, alpha=0.6)
    plt.scatter(X[y==1, 0], X[y==1, 1], c='red', edgecolors='black',
                label='Class 1', s=50, alpha=0.6)
    plt.xlabel('Feature 1')
    plt.ylabel('Feature 2')
    plt.title(title)
    plt.legend()
    plt.grid(True, alpha=0.3)
    return plt.gcf()

