print("="*60)
print("LINEAR REGRESSION")
print("="*60)

# 1. Generate synthetic data
print("\n1. GENERATING SYNTHETIC DATA:")
np.random.seed(42)
X = np.random.rand(100, 1) * 10  # 100 samples, 1 feature
true_slope = 2.5
true_intercept = 5.0
y = true_slope * X.squeeze() + true_intercept + np.random.randn(100) * 2  # Add noise

print(f"X shape: {X.shape}")
print(f"y shape: {y.shape}")
print(f"True relationship: y = {true_slope}*x + {true_intercept} + noise")

# Visualize the data
plt.figure(figsize=(10, 6))
plt.scatter(X, y, alpha=0.6, label='Data points')
plt.plot(X, true_slope * X.squeeze() + true_intercept, 'r-', label='True line', linewidth=2)
plt.xlabel('X')
plt.ylabel('y')
plt.title('Synthetic Linear Regression Data')
plt.legend()
plt.grid(True, alpha=0.3)
