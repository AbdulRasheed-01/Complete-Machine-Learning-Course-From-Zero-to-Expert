"""
WEEK 1 PROJECT: Exploratory Data Analysis on Titanic Dataset
"""

import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
import warnings
warnings.filterwarnings('ignore')

print("="*70)
print("WEEK 1 PROJECT: EXPLORATORY DATA ANALYSIS")
print("="*70)

# 1. Load the data
print("\n1. LOADING DATA:")
# Using Seaborn's built-in Titanic dataset
df = sns.load_dataset('titanic')
print(f"Dataset shape: {df.shape}")
print(f"Columns: {df.columns.tolist()}")

# 2. Initial Data Inspection
print("\n2. INITIAL DATA INSPECTION:")
print("\nFirst 5 rows:")
print(df.head())

print("\nData Info:")
print(df.info())

print("\nBasic Statistics:")
print(df.describe(include='all'))

# 3. Missing Values Analysis
print("\n3. MISSING VALUES ANALYSIS:")
missing = df.isnull().sum()
missing_pct = (missing / len(df)) * 100
missing_df = pd.DataFrame({
    'Missing Count': missing,
    'Missing %': missing_pct
})
print(missing_df[missing_df['Missing Count'] > 0].sort_values('Missing %', ascending=False))

# 4. Univariate Analysis
print("\n4. UNIVARIATE ANALYSIS:")
fig, axes = plt.subplots(2, 3, figsize=(15, 10))

# Age distribution
axes[0, 0].hist(df['age'].dropna(), bins=30, edgecolor='black', alpha=0.7)
axes[0, 0].set_title('Age Distribution')
axes[0, 0].set_xlabel('Age')
axes[0, 0].set_ylabel('Frequency')

# Fare distribution
axes[0, 1].hist(df['fare'], bins=30, edgecolor='black', alpha=0.7, color='green')
axes[0, 1].set_title('Fare Distribution')
axes[0, 1].set_xlabel('Fare')
axes[0, 1].set_ylabel('Frequency')

# Survival count
survival_counts = df['survived'].value_counts()
axes[0, 2].bar(['Died', 'Survived'], survival_counts.values, color=['red', 'green'], edgecolor='black')
axes[0, 2].set_title('Survival Count')
axes[0, 2].set_ylabel('Count')
for i, v in enumerate(survival_counts.values):
    axes[0, 2].text(i, v + 5, str(v), ha='center')

# Pclass distribution
pclass_counts = df['pclass'].value_counts().sort_index()
axes[1, 0].bar(['1st', '2nd', '3rd'], pclass_counts.values, color='skyblue', edgecolor='black')
axes[1, 0].set_title('Passenger Class Distribution')
axes[1, 0].set_ylabel('Count')

# Sex distribution
sex_counts = df['sex'].value_counts()
axes[1, 1].bar(['Male', 'Female'], sex_counts.values, color=['blue', 'pink'], edgecolor='black')
axes[1, 1].set_title('Gender Distribution')
axes[1, 1].set_ylabel('Count')

# Embarked distribution
embarked_counts = df['embarked'].value_counts()
