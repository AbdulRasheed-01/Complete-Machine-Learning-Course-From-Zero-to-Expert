range_arr = np.arange(0, 10, 2)  # start, stop, step
print(f"Range array: {range_arr}")

linspace_arr = np.linspace(0, 1, 5)  # 5 points between 0 and 1
print(f"Linspace array: {linspace_arr}")

random_arr = np.random.randn(3, 3)  # random normal distribution
print(f"\nRandom normal array:\n{random_arr}")

# 2. Array Attributes
print("\n2. ARRAY ATTRIBUTES:")
print(f"Shape: {arr2.shape}")
print(f"Dimensions: {arr2.ndim}")
