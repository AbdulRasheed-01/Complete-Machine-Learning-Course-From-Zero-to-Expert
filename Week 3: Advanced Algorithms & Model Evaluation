# svm.py
"""
Support Vector Machines for classification
"""

import numpy as np
import matplotlib.pyplot as plt
from sklearn import svm
from sklearn.datasets import make_classification, make_circles, make_moons
from sklearn.model_selection import train_test_split, GridSearchCV
from sklearn.preprocessing import StandardScaler
from sklearn.metrics import accuracy_score, confusion_matrix, classification_report
from sklearn.inspection import DecisionBoundaryDisplay
import warnings
warnings.filterwarnings('ignore')

print("="*60)
print("SUPPORT VECTOR MACHINES")
print("="*60)

# 1. Linear SVM on linearly separable data
print("\n1. LINEAR SVM:")

# Generate linearly separable data
X_linear, y_linear = make_classification(
    n_samples=200, n_features=2, n_redundant=0, n_clusters_per_class=1,
    random_state=42
)

X_train_l, X_test_l, y_train_l, y_test_l = train_test_split(
    X_linear, y_linear, test_size=0.2, random_state=42
)

# Train linear SVM
svm_linear = svm.SVC(kernel='linear', C=1.0)
svm_linear.fit(X_train_l, y_train_l)

# Predictions
y_pred_l = svm_linear.predict(X_test_l)
accuracy_l = accuracy_score(y_test_l, y_pred_l)
print(f"Linear SVM Accuracy: {accuracy_l:.4f}")

# Visualize decision boundary
def plot_svm_boundary(X, y, model, title):
    plt.figure(figsize=(10, 6))
    
    # Plot decision boundary
    DecisionBoundaryDisplay.from_estimator(
        model, X, response_method="predict",
        alpha=0.3, cmap='coolwarm', grid_resolution=100
    )
    
    # Plot data points
    plt.scatter(X[:, 0], X[:, 1], c=y, cmap='coolwarm', 
                edgecolors='black', s=50, alpha=0.7)
    
    # Highlight support vectors
    plt.scatter(model.support_vectors_[:, 0], model.support_vectors_[:, 1],
                s=200, linewidth=1, facecolors='none', edgecolors='black',
                label='Support Vectors')
    
    plt.xlabel('Feature 1')
    plt.ylabel('Feature 2')
    plt.title(title)
    plt.legend()
    plt.grid(True, alpha=0.3)
    return plt.gcf()

plot_svm_boundary(X_train_l, y_train_l, svm_linear, 'Linear SVM Decision Boundary')
plt.savefig('svm_linear.png')
plt.show()
print("✅ Linear SVM boundary saved as 'svm_linear.png'")

# 2. SVM with different C values (regularization)
print("\n2. EFFECT OF C PARAMETER (REGULARIZATION):")

C_values = [0.01, 0.1, 1, 10, 100]
fig, axes = plt.subplots(1, 5, figsize=(20, 4))

for i, C in enumerate(C_values):
    svm_c = svm.SVC(kernel='linear', C=C)
    svm_c.fit(X_train_l, y_train_l)
    
    DecisionBoundaryDisplay.from_estimator(
        svm_c, X_train_l, response_method="predict",
        alpha=0.2, cmap='coolwarm', grid_resolution=100, ax=axes[i]
    )
    
    axes[i].scatter(X_train_l[:, 0], X_train_l[:, 1], c=y_train_l,
                    cmap='coolwarm', edgecolors='black', s=30, alpha=0.7)
    axes[i].scatter(svm_c.support_vectors_[:, 0], svm_c.support_vectors_[:, 1],
                    s=100, linewidth=1, facecolors='none', edgecolors='black')
    axes[i].set_title(f'C = {C}')
    axes[i].set_xlabel('Feature 1')
    axes[i].set_ylabel('Feature 2')
    axes[i].grid(True, alpha=0.3)

plt.tight_layout()
plt.savefig('svm_c_values.png')
plt.show()
print("✅ C parameter analysis saved as 'svm_c_values.png'")

# 3. SVM with RBF kernel on non-linear data
print("\n3. SVM WITH RBF KERNEL (NON-LINEAR):")

# Generate non-linear data (circles)
X_circles, y_circles = make_circles(n_samples=300, noise=0.1, factor=0.3, random_state=42)

X_train_c, X_test_c, y_train_c, y_test_c = train_test_split(
    X_circles, y_circles, test_size=0.2, random_state=42
)

# Scale features
scaler = StandardScaler()
X_train_c_scaled = scaler.fit_transform(X_train_c)
X_test_c_scaled = scaler.transform(X_test_c)

# Train SVM with different kernels
kernels = ['linear', 'poly', 'rbf', 'sigmoid']
fig, axes = plt.subplots(2, 2, figsize=(12, 12))

for ax, kernel in zip(axes.flatten(), kernels):
    svm_kernel = svm.SVC(kernel=kernel, C=1.0, gamma='scale')
    svm_kernel.fit(X_train_c_scaled, y_train_c)
    
    # Accuracy
    y_pred_k = svm_kernel.predict(X_test_c_scaled)
    acc = accuracy_score(y_test_c, y_pred_k)
    
    # Plot
    DecisionBoundaryDisplay.from_estimator(
        svm_kernel, X_train_c_scaled, response_method="predict",
        alpha=0.3, cmap='coolwarm', grid_resolution=100, ax=ax
    )
    
    ax.scatter(X_train_c_scaled[:, 0], X_train_c_scaled[:, 1], 
               c=y_train_c, cmap='coolwarm', edgecolors='black', s=30, alpha=0.7)
    ax.scatter(svm_kernel.support_vectors_[:, 0], svm_kernel.support_vectors_[:, 1],
               s=100, linewidth=1, facecolors='none', edgecolors='black')
    ax.set_title(f'{kernel.capitalize()} Kernel (Acc: {acc:.3f})')
    ax.grid(True, alpha=0.3)

plt.tight_layout()
plt.savefig('svm_kernels.png')
plt.show()
print("✅ Kernel comparison saved as 'svm_kernels.png'")

# 4. Effect of gamma parameter in RBF kernel
print("\n4. EFFECT OF GAMMA PARAMETER (RBF KERNEL):")

gamma_values = [0.1, 1, 10, 100]
