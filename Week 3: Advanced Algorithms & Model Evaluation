    fraud_caught = tp * (daily_transactions / len(y_test))
    fraud_missed = fn * (daily_transactions / len(y_test))
    false_alarms = fp * (daily_transactions / len(y_test))
    
    # Financial impact
    savings = fraud_caught * fraud_amount
    costs = false_alarms * investigation_cost
    net_benefit = savings - costs
    
    print(f"\n{name}:")
    print(f"  Fraud caught per day: {fraud_caught:.1f}")
    print(f"  Fraud missed per day: {fraud_missed:.1f}")
    print(f"  False alarms per day: {false_alarms:.1f}")
    print(f"  Daily savings: ${savings:,.0f}")
    print(f"  Daily investigation costs: ${costs:,.0f}")
